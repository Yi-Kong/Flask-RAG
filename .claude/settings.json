{
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.production)",
      "Read(.env.development)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.production)",
      "Read(**/.env.development)",
      "Read(secrets/**)",
      "Read(**/secrets/**)",
      "Read(*.pem)",
      "Read(**/*.pem)",
      "Read(*.key)",
      "Read(**/*.key)",
      "Read(*credentials*)",
      "Read(**/*credentials*)",
      "Read(*secret*)",
      "Read(**/*secret*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[安全检查] 即将执行 Bash 命令\""
          }
        ]
      }
    ]
  }
}
