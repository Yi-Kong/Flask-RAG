# ============================================================
# 校园知识库 RAG 系统 — 环境变量配置模板
# 复制此文件为 .env 并修改对应值（所有配置项均为必填）:
#   cp .env.example .env
# ============================================================

# ── Flask 应用配置 ──────────────────────────────────────────
# Flask 密钥（用于 session/flash），请务必修改为随机字符串
SECRET_KEY=change-me-to-a-random-secret-string

# 调试模式 (True/False)，生产环境务必设为 False
FLASK_DEBUG=True

# Flask 运行端口
FLASK_PORT=5001

# ── Cookie 配置 ─────────────────────────────────────────────
# Token Cookie 有效期（秒）
COOKIE_MAX_AGE=7200

# Cookie HttpOnly 标记 (True/False)
COOKIE_HTTPONLY=True

# Cookie SameSite 属性 (Strict/Lax/None)
COOKIE_SAMESITE=Lax

# ── JWT 配置 ────────────────────────────────────────────────
# JWT 签名密钥（必填，生产环境务必修改为随机字符串）
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret

# JWT Token 有效期（小时）
JWT_EXPIRATION_HOURS=2

# ── Coze API 配置（仅使用小红书生成功能时需要）─────────────
# Coze 工作流 API Token
# COZE_API_TOKEN=your-coze-pat-token-here

# Coze 工作流 ID
# COZE_WORKFLOW_ID=your-workflow-id-here

# ── MySQL 数据库配置 ────────────────────────────────────────
# 数据库连接地址 (SQLAlchemy 格式)
DATABASE_URL=mysql+pymysql://root:123456@127.0.0.1:3306/campus_rag?charset=utf8mb4

# SQL 语句日志 (True/False)
SQLALCHEMY_ECHO=True

# ── 文件上传配置 ─────────────────────────────────────────────
# 上传文件存储目录（相对于项目根目录）
UPLOAD_FOLDER=uploads

# 最大上传文件大小（字节），如 52428800 = 50MB
MAX_CONTENT_LENGTH=52428800

# 允许上传的文件扩展名（逗号分隔）
ALLOWED_EXTENSIONS=pdf,docx,txt,md,markdown

# ── 文本分块配置 ─────────────────────────────────────────────
# 每个分块的最大字符数
CHUNK_SIZE=500

# 分块间的重叠字符数
CHUNK_OVERLAP=50

# ── 嵌入模型配置 ─────────────────────────────────────────────
# 嵌入模型名或本地路径
#   - "BAAI/bge-small-zh-v1.5" → 从 HuggingFace 在线下载
#   - "embedding_models/bge-small-zh-v1.5" → 使用本地下载的模型
EMBEDDING_MODEL=embedding_models/bge-small-zh-v1.5

# 嵌入批处理大小
EMBEDDING_BATCH_SIZE=32

# ── ChromaDB 向量数据库配置 ──────────────────────────────────
# ChromaDB 服务地址（HttpClient 客户端-服务器模式）
# 需先启动: chroma run --host 127.0.0.1 --port 8000 --path ./chroma_data
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8000

# 存储策略:
#   single_collection - 所有文档存入单个集合（旧方案）
#   per_document      - 每文档创建一个独立集合（推荐，删除更快、单文档搜索更精准）
CHROMA_STORAGE_STRATEGY=per_document

# 单集合模式下的集合名（per_document 模式忽略此项）
CHROMA_COLLECTION=document_chunks

# per_document 模式下集合名前缀
# 集合名格式: {prefix}{document_id}，例如 doc_3
CHROMA_COLLECTION_PREFIX=doc_

# ── DeepSeek API 配置 ───────────────────────────────────────
# DeepSeek API Key（从 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY=your-api-key-here

# DeepSeek API 地址
DEEPSEEK_BASE_URL=https://api.deepseek.com

# DeepSeek 模型名称
DEEPSEEK_MODEL=deepseek-chat

# 请求超时时间（秒）
DEEPSEEK_TIMEOUT=60

# 最大生成 Token 数
DEEPSEEK_MAX_TOKENS=2048

# 生成温度（0-1，越低越确定）
DEEPSEEK_TEMPERATURE=0.3

# ── 向量搜索配置 ────────────────────────────────────────────
# 搜索返回结果数量（用于 check_vectors.py）
SEARCH_TOP_N=3

# ── HuggingFace 模型下载配置 ─────────────────────────────────
# 模型仓库 ID（用于 download_model.py）
HF_MODEL_NAME=BAAI/bge-small-zh-v1.5

# HuggingFace 镜像端点（国内用户推荐: https://hf-mirror.com）
# HF_ENDPOINT=https://hf-mirror.com

# ── GitHub MCP 配置 ────────────────────────────────────────
# GitHub Personal Access Token（用于 GitHub MCP 服务器）
# 获取方式: GitHub → Settings → Developer settings → Personal access tokens
# 需要 repo、read:org 等权限
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
